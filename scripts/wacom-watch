#!/usr/bin/env bash
# wacom-watch: Wacom Cintiq mapping supervisor.
#
# Three duties:
#   1. Apply wacom-remap once at startup.
#   2. Listen for X RandR events (layout change, plug or unplug, KDE
#      Edit Mode) and re-apply on each, debounced by one second.
#   3. Poll the stylus Coordinate Transformation Matrix every 5 seconds;
#      if it has been reset to the identity matrix by some non-RandR
#      actor (KDE's wacomtablet daemon, libinput hotplug, an app grabbing
#      the device, etc.) re-apply. This is the belt-and-braces layer.
#
# Started by systemd (see wacom-watch.service alongside this script).
#
# Log: ~/.cache/wacom-watch.log
# Also visible via: journalctl --user -u wacom-watch.service

set -uo pipefail

LOG=~/.cache/wacom-watch.log
exec >>"$LOG" 2>&1

REMAP=~/.local/bin/wacom-remap
POLL_INTERVAL=5
IDENTITY_CTM="1.000000, 0.000000, 0.000000, 0.000000, 1.000000, 0.000000, 0.000000, 0.000000, 1.000000"

# Resolve the stylus device name by TYPE rather than hardcoding it. The
# reported name drifts across driver updates, and a stale string broke the
# watchdog silently in the past: it polled a name that no longer existed,
# so it never detected the reset and never recovered. Re-resolved on every
# poll, so even a hotplug rename heals itself.
stylus_name() {
  xsetwacom --list devices | awk -F'\t' '
    $1 ~ /Cintiq/ && index($3, "type: STYLUS") {
      gsub(/[ \t]+$/, "", $1); print $1; exit
    }'
}

echo "[$(date)] wacom-watch starting (pid $$)"

"$REMAP" || true

randr_listener() {
  local last_run=0 now
  xev -root -event randr 2>/dev/null | while read -r line; do
    case "$line" in
      *RRScreenChangeNotify*|*RRCrtcChangeNotify*|*RROutputChangeNotify*)
        now=$(date +%s)
        if [ $((now - last_run)) -ge 1 ]; then
          sleep 1
          echo "[$(date)] RandR event -> remap"
          "$REMAP" || true
          last_run=$(date +%s)
        fi
        ;;
    esac
  done
}

ctm_watchdog() {
  local ctm stylus
  while sleep "$POLL_INTERVAL"; do
    stylus=$(stylus_name)
    [ -z "$stylus" ] && continue   # tablet unplugged; nothing to poll
    ctm=$(xinput list-props "$stylus" 2>/dev/null \
          | awk -F'\t' '/Coordinate Transformation Matrix/ { print $NF }')
    [ -z "$ctm" ] && continue
    if [ "$ctm" = "$IDENTITY_CTM" ]; then
      echo "[$(date)] CTM watchdog: identity matrix detected -> remap"
      "$REMAP" || true
    fi
  done
}

randr_listener &
RANDR_PID=$!
ctm_watchdog &
WATCHDOG_PID=$!

trap 'kill $RANDR_PID $WATCHDOG_PID 2>/dev/null; exit' EXIT INT TERM

wait -n
echo "[$(date)] a child exited; terminating so systemd can restart us"
exit 1
